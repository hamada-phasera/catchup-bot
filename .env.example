# Discord Developer Portal で取得したボットのトークン
DISCORD_TOKEN=
# Google AI Studio で取得した Gemini の API キー
GEMINI_API_KEY=
# PostgreSQL への接続情報
# ローカル(docker compose)の場合: postgres://catchup:abc123@postgres:5432/catchup
# Render の場合: Render の PostgreSQL の Internal Database URL
DB_INFO=postgres://catchup:abc123@postgres:5432/catchup
# Render が指定してくるポート番号（ローカルでは 3000 で動く）
PORT=3000
